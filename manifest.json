{
  "manifest_version": 3,
  "name": "Cold Open",
  "version": "0.1.0",
  "description": "Injects IMDB ratings into Reddit episode threads, and Reddit discussions into IMDB pages.",
  "permissions": ["storage"],
  "host_permissions": [
    "*://www.reddit.com/*",
    "*://old.reddit.com/*",
    "*://www.omdbapi.com/*",
    "*://www.imdb.com/*",
    "*://www.reddit.com/search.json*"
  ],
  "content_scripts": [
    {
      "matches": ["*://www.reddit.com/*", "*://old.reddit.com/*"],
      "js": ["src/content.tsx"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["*://www.imdb.com/*"],
      "js": ["src/contentIMDB.tsx"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
